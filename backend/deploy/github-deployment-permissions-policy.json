{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EcrLogin",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "PushQuickBiteImages",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:CompleteLayerUpload",
        "ecr:DescribeImages",
        "ecr:DescribeRepositories",
        "ecr:GetDownloadUrlForLayer",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart"
      ],
      "Resource": [
        "arn:aws:ecr:eu-north-1:455919270013:repository/core-service",
        "arn:aws:ecr:eu-north-1:455919270013:repository/order-service",
        "arn:aws:ecr:eu-north-1:455919270013:repository/analytics-service"
      ]
    },
    {
      "Sid": "RunMigrationTasks",
      "Effect": "Allow",
      "Action": "ecs:RunTask",
      "Resource": [
        "arn:aws:ecs:eu-north-1:455919270013:task-definition/core-migrate:*",
        "arn:aws:ecs:eu-north-1:455919270013:task-definition/order-migrate:*"
      ],
      "Condition": {
        "ArnEquals": {
          "ecs:cluster": "arn:aws:ecs:eu-north-1:455919270013:cluster/quickbite-1"
        }
      }
    },
    {
      "Sid": "UpdateQuickBiteServices",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices",
        "ecs:UpdateService"
      ],
      "Resource": [
        "arn:aws:ecs:eu-north-1:455919270013:service/quickbite-1/core-service",
        "arn:aws:ecs:eu-north-1:455919270013:service/quickbite-1/core-worker",
        "arn:aws:ecs:eu-north-1:455919270013:service/quickbite-1/order-service",
        "arn:aws:ecs:eu-north-1:455919270013:service/quickbite-1/analytics-service"
      ]
    },
    {
      "Sid": "ReadTaskStatus",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeClusters",
        "ecs:DescribeTasks",
        "ecs:DescribeTaskDefinition",
        "ecs:ListTasks"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassFargateExecutionRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::455919270013:role/ecsTaskExecutionRole",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    }
  ]
}
