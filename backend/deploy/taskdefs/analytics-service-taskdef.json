{
  "family": "analytics-service",
  "executionRoleArn": "arn:aws:iam::455919270013:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "analytics-service",
      "image": "455919270013.dkr.ecr.eu-north-1.amazonaws.com/analytics-service:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "analytics-service-3000-tcp",
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "MONGO_DATABASE",
          "value": "analytics"
        },
        {
          "name": "CORE_SERVICE_BASE_URL",
          "value": "http://core-service:3000"
        },
        {
          "name": "RABBITMQ_ORDER_EVENTS_EXCHANGE",
          "value": "order.events"
        },
        {
          "name": "RABBITMQ_ORDER_EVENTS_QUEUE",
          "value": "analytics-service.order-events"
        },
        {
          "name": "RABBITMQ_ORDER_EVENTS_BINDINGS",
          "value": "order.#,payment.#"
        },
        {
          "name": "RABBITMQ_ORDER_EVENTS_DLX",
          "value": "order.events.dlx"
        },
        {
          "name": "RABBITMQ_ORDER_EVENTS_DLQ",
          "value": "analytics-service.order-events.dlq"
        },
        {
          "name": "RABBITMQ_CORE_EVENTS_EXCHANGE",
          "value": "core.events"
        },
        {
          "name": "RABBITMQ_CORE_EVENTS_QUEUE",
          "value": "analytics-service.core-events"
        },
        {
          "name": "RABBITMQ_CORE_EVENTS_BINDINGS",
          "value": "rbac.#"
        },
        {
          "name": "RABBITMQ_CORE_EVENTS_DLX",
          "value": "core.events.dlx"
        },
        {
          "name": "RABBITMQ_CORE_EVENTS_DLQ",
          "value": "analytics-service.core-events.dlq"
        },
        {
          "name": "RABBITMQ_PREFETCH",
          "value": "32"
        },
        {
          "name": "RBAC_CACHE_TTL_SEC",
          "value": "300s"
        }
      ],
      "secrets": [
        {
          "name": "MONGO_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:analytics/mongo-xaj9Gm:MONGO_URL::"
        },
        {
          "name": "RABBITMQ_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:mq-URwQfp:RABBITMQ_URL::"
        },
        {
          "name": "ACCESS_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:core/auth-1I4ppb:JWT_ACCESS_SECRET::"
        },
        {
          "name": "CORE_INTERNAL_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:core/internal-JAB9k2:INTERNAL_API_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/analytics-service",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
