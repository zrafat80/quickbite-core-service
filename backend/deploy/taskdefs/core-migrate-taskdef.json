{
  "family": "core-migrate",
  "executionRoleArn": "arn:aws:iam::455919270013:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "app",
      "image": "455919270013.dkr.ecr.eu-north-1.amazonaws.com/core-service:latest",
      "essential": true,
      "command": [
        "node",
        "-e",
        "const knex=require('knex');const db=knex({client:'pg',connection:{host:process.env.DB_HOST,port:Number(process.env.DB_PORT||5432),user:process.env.DB_USERNAME,password:process.env.DB_PASSWORD,database:process.env.DB_DATABASE,ssl:{rejectUnauthorized:false}},pool:{min:Number(process.env.DB_POOL_MIN||0),max:Number(process.env.DB_POOL_MAX||10)},migrations:{directory:process.env.DB_MIGRATION_DIRECTORY||'dist/database/migrations',extension:process.env.DB_MIGRATION_EXTENSION||'js'}});db.migrate.latest().then(r=>{console.log('core migrated',JSON.stringify(r));return db.destroy();}).catch(e=>{console.error(e);db.destroy().finally(()=>process.exit(1));});"
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "DB_POOL_MIN",
          "value": "0"
        },
        {
          "name": "DB_POOL_MAX",
          "value": "10"
        },
        {
          "name": "DB_MIGRATION_DIRECTORY",
          "value": "dist/database/migrations"
        },
        {
          "name": "DB_MIGRATION_EXTENSION",
          "value": "js"
        }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:core/db-7dk4nx:DB_HOST::"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:core/db-7dk4nx:DB_PORT::"
        },
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:core/db-7dk4nx:DB_USERNAME::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:core/db-7dk4nx:DB_PASSWORD::"
        },
        {
          "name": "DB_DATABASE",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:455919270013:secret:core/db-7dk4nx:DB_DATABASE::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/core-migrate",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
